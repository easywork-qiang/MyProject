<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>жЏ’д»¶з®Ўзђ† - RC Assist з®Ўзђ†еђЋеЏ°</title>
    <link rel="stylesheet" href="/admin/css/style.css">
    <style>
        .btn-group { display: inline-flex; gap: 4px; flex-wrap: wrap; }
        .modal { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 1000; justify-content: center; align-items: center; }
        .modal-content { background: #fff; border-radius: 12px; padding: 24px; max-width: 560px; width: 90%; max-height: 80vh; overflow-y: auto; }
        .modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
        .version-current { background: rgba(0,184,148,0.1); }
        .version-current td { font-weight: 600; }
        .badge-new-version { background: #e17055; color: #fff; font-size: 11px; padding: 2px 6px; border-radius: 4px; margin-left: 6px; animation: pulse-badge 2s infinite; }
        @keyframes pulse-badge { 0%, 100% { opacity: 1; } 50% { opacity: 0.7; } }
        .size-cell { font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace; font-size: 12px; color: #666; }
    </style>
</head>
<body>
<div class="app-container">
    <%- include('layout') %>
    <main class="main-content">
        <div class="page-header" style="display:flex; justify-content:space-between; align-items:center;">
            <h1>рџ§© жЏ’д»¶з®Ўзђ†</h1>
            <button class="btn btn-primary" id="publishAllBtn" onclick="publishAll()">
                рџ”„ ж‰«жЏЏеЅ’жЎЈе№¶еЏ‘еёѓ
            </button>
        </div>

        <!-- ж ёеїѓз»„д»¶ -->
        <div class="card">
            <div class="card-header"><h3>рџ”§ ж ёеїѓз»„д»¶</h3></div>
            <div class="card-body">
                <table class="table">
                    <thead><tr><th>з»„д»¶ ID</th><th>Core Key</th><th>еЅ“е‰Ќз‰€жњ¬</th><th>ж–‡д»¶</th><th>ж“ЌдЅњ</th></tr></thead>
                    <tbody>
                        <% Object.keys(manifest.core || {}).forEach(function(key) { var c = manifest.core[key]; var coreId = key.replace(/([A-Z])/g, '-$1').toLowerCase().replace(/^-/, ''); var latestCore = (latestArchiveVersions.core || {})[coreId]; %> 
                        <tr>
                            <td><strong><%= coreId %></strong></td>
                            <td><code><%= key %></code></td>
                            <td>
                                <span class="badge badge-success"><%= c.version %></span>
                                <% if (latestCore && latestCore.version !== c.version) { %>
                                <span class="badge-new-version" title="еЅ’жЎЈдё­жњ‰ж–°з‰€жњ¬ v<%= latestCore.version %>">жњ‰ж–°з‰€жњ¬</span>
                                <% } %>
                            </td>
                            <td><code><%= c.file %></code></td>
                            <td>
                                <div class="btn-group">
                                    <button class="btn btn-sm" onclick="showCoreVersions('<%= coreId %>', '<%= c.version %>')">з‰€жњ¬</button>
                                    <button class="btn btn-sm btn-danger" onclick="deleteCoreComponent('<%= coreId %>')">з§»й™¤</button>
                                </div>
                            </td>
                        </tr>
                        <% }); %>
                        <% if (Object.keys(manifest.core || {}).length === 0) { %>
                        <tr><td colspan="5" class="text-center text-muted">жљ‚ж— ж ёеїѓз»„д»¶</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- жЏ’д»¶е€—иЎЁ -->
        <div class="card">
            <div class="card-header"><h3>жЏ’д»¶е€—иЎЁ</h3></div>
            <div class="card-body">
                <table class="table">
                    <thead><tr><th>жЏ’д»¶ ID</th><th>еђЌз§°</th><th>еЅ“е‰Ќз‰€жњ¬</th><th>ж јејЏ</th><th>е¤§е°Џ</th><th>ж“ЌдЅњ</th></tr></thead>
                    <tbody>
                        <% (manifest.plugins || []).forEach(function(p) { var latestPlugin = (latestArchiveVersions.plugins || {})[p.id]; %>
                        <tr>
                            <td><strong><%= p.id %></strong></td>
                            <td><%= p.name || p.id %></td>
                            <td>
                                <span class="badge badge-success"><%= p.version %></span>
                                <% if (latestPlugin && latestPlugin.version !== p.version) { %>
                                <span class="badge-new-version" title="еЅ’жЎЈдё­жњ‰ж–°з‰€жњ¬ v<%= latestPlugin.version %>">жњ‰ж–°з‰€жњ¬</span>
                                <% } %>
                            </td>
                            <td>
                                <% if (p.format === 'zip') { %>
                                <span class="badge" style="background:#2d7d46;color:#fff;" title="<%= (p.files || []).join(', ') %>">рџ“¦ ZIP</span>
                                <% } else { %>
                                <span class="badge" style="background:#555;color:#fff;">JS</span>
                                <% } %>
                            </td>
                            <td class="size-cell">
                                <% var size = pluginSizes[p.id]; %>
                                <% if (size) { %>
                                    <% if (size < 1024) { %>
                                    <%= size %> B
                                    <% } else if (size < 1024 * 1024) { %>
                                    <%= (size / 1024).toFixed(1) %> KB
                                    <% } else { %>
                                    <%= (size / 1024 / 1024).toFixed(2) %> MB
                                    <% } %>
                                <% } else { %>
                                <span class="text-muted">-</span>
                                <% } %>
                            </td>
                            <td>
                                <div class="btn-group">
                                    <button class="btn btn-sm" onclick="showVersions('<%= p.id %>', '<%= p.version %>')">з‰€жњ¬</button>
                                    <button class="btn btn-sm btn-danger" onclick="deletePlugin('<%= p.id %>')">з§»й™¤</button>
                                </div>
                            </td>
                        </tr>
                        <% }); %>
                        <% if ((manifest.plugins || []).length === 0) { %>
                        <tr><td colspan="6" class="text-center text-muted">жљ‚ж— жЏ’д»¶</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- з‰€жњ¬з®Ўзђ†еј№зЄ—пј€жЏ’д»¶пј‰ -->
        <div class="modal" id="versionModal">
            <div class="modal-content">
                <div class="modal-header">
                    <h3>рџ“¦ з‰€жњ¬з®Ўзђ† - <span id="versionPluginId"></span></h3>
                    <button class="btn btn-sm" onclick="closeModal()">вњ•</button>
                </div>
                <div class="modal-body" id="versionBody">еЉ иЅЅдё­...</div>
            </div>
        </div>

        <!-- з‰€жњ¬з®Ўзђ†еј№зЄ—пј€ж ёеїѓз»„д»¶пј‰ -->
        <div class="modal" id="coreVersionModal">
            <div class="modal-content">
                <div class="modal-header">
                    <h3>рџ”§ ж ёеїѓз»„д»¶з‰€жњ¬з®Ўзђ† - <span id="coreVersionId"></span></h3>
                    <button class="btn btn-sm" onclick="closeCoreModal()">вњ•</button>
                </div>
                <div class="modal-body" id="coreVersionBody">еЉ иЅЅдё­...</div>
            </div>
        </div>
    </main>
</div>
<script>

function formatChinaTime(val) {
    if (!val) return '';
    const d = new Date(val);
    if (isNaN(d.getTime())) return val;
    return d.toLocaleString('zh-CN', {
        timeZone: 'Asia/Shanghai',
        year: 'numeric', month: '2-digit', day: '2-digit',
        hour: '2-digit', minute: '2-digit', second: '2-digit',
        hour12: false,
    }).replace(/\//g, '-');
}

// ==================== жЏ’д»¶з‰€жњ¬з®Ўзђ† ====================

let currentPluginVersion = '';

function showVersions(pluginId, currentVersion) {
    currentPluginVersion = currentVersion;
    document.getElementById('versionPluginId').textContent = pluginId;
    document.getElementById('versionModal').style.display = 'flex';
    document.getElementById('versionBody').innerHTML = 'еЉ иЅЅдё­...';

    fetch('/admin/api/plugins/' + pluginId + '/archive')
        .then(r => r.json())
        .then(files => {
            if (files.length === 0) {
                document.getElementById('versionBody').innerHTML =
                    '<p>еЅ“е‰Ќз‰€жњ¬: <span class="badge badge-success">' + currentVersion + '</span></p>' +
                    '<p class="text-muted">жљ‚ж— еЋ†еЏІз‰€жњ¬</p>';
                return;
            }

            let html = '<p style="margin-bottom:12px;">еЅ“е‰ЌеЏ‘еёѓз‰€жњ¬: <span class="badge badge-success">' + currentVersion + '</span></p>';
            html += '<table class="table"><thead><tr><th>з‰€жњ¬</th><th>ж јејЏ</th><th>е¤§е°Џ</th><th>дёЉдј ж—¶й—ґ</th><th>ж“ЌдЅњ</th></tr></thead><tbody>';
            html += files.map(function(f) {
                const isCurrent = f.version === currentVersion;
                const rowClass = isCurrent ? 'version-current' : '';
                const actionBtn = isCurrent
                    ? '<span class="badge badge-success">еЅ“е‰Ќз‰€жњ¬</span>'
                    : '<button class="btn btn-sm btn-primary" onclick="publishVersion(\'' + pluginId + '\',\'' + f.version + '\')">еЏ‘еёѓ</button>';
                return '<tr class="' + rowClass + '"><td>' + f.version + '</td><td>' + (f.format === 'zip' ? 'рџ“¦ ZIP' : 'JS') + '</td><td>' + (f.size / 1024).toFixed(1) + ' KB</td><td>' + formatChinaTime(f.modifiedAt) + '</td><td>' + actionBtn + '</td></tr>';
            }).join('');
            html += '</tbody></table>';

            document.getElementById('versionBody').innerHTML = html;
        })
        .catch(function(err) {
            document.getElementById('versionBody').innerHTML = '<p class="text-muted">еЉ иЅЅе¤±иґҐ: ' + err.message + '</p>';
        });
}

function publishVersion(pluginId, version) {
    if (!confirm('зЎ®е®љи¦Ѓе°† ' + pluginId + ' еЏ‘еёѓдёє v' + version + ' еђ—пјџж‰Ђжњ‰е®ўж€·з«Їе°†еђЊж­Ґж­¤з‰€жњ¬гЂ‚')) return;
    fetch('/admin/api/plugins/' + pluginId + '/rollback', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ version })
    }).then(r => r.json()).then(data => {
        if (data.ok) { alert('вњ… е·ІеЏ‘еёѓ v' + version); location.reload(); }
        else alert('еЏ‘еёѓе¤±иґҐ: ' + data.error);
    });
}

function deletePlugin(pluginId) {
    if (!confirm('зЎ®е®љи¦Ѓд»Ћ manifest дё­з§»й™¤жЏ’д»¶ ' + pluginId + ' еђ—пјџ')) return;
    fetch('/admin/api/plugins/' + pluginId, { method: 'DELETE' })
        .then(r => r.json()).then(data => {
            if (data.message) { alert('з§»й™¤ж€ђеЉџ'); location.reload(); }
            else alert('з§»й™¤е¤±иґҐ: ' + data.error);
        });
}

function closeModal() {
    document.getElementById('versionModal').style.display = 'none';
}

// ==================== ж ёеїѓз»„д»¶з‰€жњ¬з®Ўзђ† ====================

let currentCoreVersion = '';

function showCoreVersions(coreId, currentVersion) {
    currentCoreVersion = currentVersion;
    document.getElementById('coreVersionId').textContent = coreId;
    document.getElementById('coreVersionModal').style.display = 'flex';
    document.getElementById('coreVersionBody').innerHTML = 'еЉ иЅЅдё­...';

    fetch('/admin/api/core/' + coreId + '/archive')
        .then(r => r.json())
        .then(files => {
            if (files.length === 0) {
                document.getElementById('coreVersionBody').innerHTML =
                    '<p>еЅ“е‰Ќз‰€жњ¬: <span class="badge badge-success">' + currentVersion + '</span></p>' +
                    '<p class="text-muted">жљ‚ж— еЋ†еЏІз‰€жњ¬</p>';
                return;
            }

            let html = '<p style="margin-bottom:12px;">еЅ“е‰ЌеЏ‘еёѓз‰€жњ¬: <span class="badge badge-success">' + currentVersion + '</span></p>';
            html += '<table class="table"><thead><tr><th>з‰€жњ¬</th><th>е¤§е°Џ</th><th>дёЉдј ж—¶й—ґ</th><th>ж“ЌдЅњ</th></tr></thead><tbody>';
            html += files.map(function(f) {
                const isCurrent = f.version === currentVersion;
                const rowClass = isCurrent ? 'version-current' : '';
                const actionBtn = isCurrent
                    ? '<span class="badge badge-success">еЅ“е‰Ќз‰€жњ¬</span>'
                    : '<button class="btn btn-sm btn-primary" onclick="publishCoreVersion(\'' + coreId + '\',\'' + f.version + '\')">еЏ‘еёѓ</button>';
                return '<tr class="' + rowClass + '"><td>' + f.version + '</td><td>' + (f.size / 1024).toFixed(1) + ' KB</td><td>' + formatChinaTime(f.modifiedAt) + '</td><td>' + actionBtn + '</td></tr>';
            }).join('');
            html += '</tbody></table>';

            document.getElementById('coreVersionBody').innerHTML = html;
        })
        .catch(function(err) {
            document.getElementById('coreVersionBody').innerHTML = '<p class="text-muted">еЉ иЅЅе¤±иґҐ: ' + err.message + '</p>';
        });
}

function publishCoreVersion(coreId, version) {
    if (!confirm('зЎ®е®љи¦Ѓе°†ж ёеїѓз»„д»¶ ' + coreId + ' еЏ‘еёѓдёє v' + version + ' еђ—пјџе®ўж€·з«Їй‡ЌеђЇеђЋе°†еђЊж­Ґж­¤з‰€жњ¬гЂ‚')) return;
    fetch('/admin/api/core/' + coreId + '/publish', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ version })
    }).then(r => r.json()).then(data => {
        if (data.ok) { alert('вњ… ж ёеїѓз»„д»¶е·ІеЏ‘еёѓ v' + version); location.reload(); }
        else alert('еЏ‘еёѓе¤±иґҐ: ' + (data.error || 'жњЄзџҐй”™иЇЇ'));
    });
}

function deleteCoreComponent(coreId) {
    if (!confirm('зЎ®е®љи¦Ѓд»Ћ manifest дё­з§»й™¤ж ёеїѓз»„д»¶ ' + coreId + ' еђ—пјџ')) return;
    fetch('/admin/api/core/' + coreId, { method: 'DELETE' })
        .then(r => r.json()).then(data => {
            if (data.message) { alert('з§»й™¤ж€ђеЉџ'); location.reload(); }
            else alert('з§»й™¤е¤±иґҐ: ' + (data.error || 'жњЄзџҐй”™иЇЇ'));
        });
}

function closeCoreModal() {
    document.getElementById('coreVersionModal').style.display = 'none';
}

// ==================== ж‰№й‡ЏеЏ‘еёѓ ====================

function publishAll() {
    if (!confirm('е°†ж‰«жЏЏеЅ’жЎЈз›®еЅ•пјЊи‡ЄеЉЁеЏ‘еёѓж‰Ђжњ‰з»„д»¶е’ЊжЏ’д»¶зљ„жњЂж–°з‰€жњ¬е€° manifestгЂ‚\nзЎ®е®љз»§з»­пјџ')) return;
    const btn = document.getElementById('publishAllBtn');
    btn.disabled = true;
    btn.textContent = 'вЏі еЏ‘еёѓдё­...';

    fetch('/admin/api/publish-all', { method: 'POST' })
        .then(r => r.json())
        .then(data => {
            if (data.ok) {
                let msg = 'вњ… ж‰№й‡ЏеЏ‘еёѓе®Њж€ђпјЃ\n\n';
                if (data.core.length) msg += 'ж ёеїѓз»„д»¶ (' + data.core.length + '):\n' + data.core.map(c => '  вЂў ' + c.id + ' v' + c.version).join('\n') + '\n\n';
                if (data.plugins.length) msg += 'жЏ’д»¶ (' + data.plugins.length + '):\n' + data.plugins.map(p => '  вЂў ' + p.id + ' v' + p.version).join('\n') + '\n\n';
                if (data.errors && data.errors.length) msg += 'вљ пёЏ е¤±иґҐ (' + data.errors.length + '):\n' + data.errors.map(e => '  вЂў ' + e.id + ': ' + e.error).join('\n');
                if (!data.core.length && !data.plugins.length) msg += 'еЅ’жЎЈз›®еЅ•дёєз©єпјЊжІЎжњ‰еЏЇеЏ‘еёѓзљ„е†…е®№гЂ‚';
                alert(msg);
                if (data.core.length || data.plugins.length) location.reload();
            } else {
                alert('еЏ‘еёѓе¤±иґҐ: ' + (data.error || 'жњЄзџҐй”™иЇЇ'));
            }
            btn.disabled = false;
            btn.textContent = 'рџ”„ ж‰«жЏЏеЅ’жЎЈе№¶еЏ‘еёѓ';
        })
        .catch(err => {
            alert('иЇ·ж±‚е¤±иґҐ: ' + err.message);
            btn.disabled = false;
            btn.textContent = 'рџ”„ ж‰«жЏЏеЅ’жЎЈе№¶еЏ‘еёѓ';
        });
}
</script>
</body>
</html>
