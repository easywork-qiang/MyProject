<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>概览 - RC Assist 管理后台</title>
    <link rel="stylesheet" href="/admin/css/style.css">
    <script src="/admin/js/vendor/chart.umd.min.js"></script>
</head>
<body>
<div class="app-container">
    <%- include('layout') %>
    <main class="main-content">
        <div class="page-header">
            <h1>📊 概览 Dashboard</h1>
        </div>

        <div class="stats-cards">
            <div class="stat-card"><div class="stat-icon">👥</div><div class="stat-info"><div class="stat-value"><%= overview.totalUsers %></div><div class="stat-label">总注册用户</div></div></div>
            <div class="stat-card stat-card-success"><div class="stat-icon">🟢</div><div class="stat-info"><div class="stat-value"><%= overview.onlineUsers %></div><div class="stat-label">当前在线</div></div></div>
            <div class="stat-card stat-card-info"><div class="stat-icon">🧩</div><div class="stat-info"><div class="stat-value"><%= overview.pluginCount %></div><div class="stat-label">已发布插件</div></div></div>
            <div class="stat-card stat-card-warning"><div class="stat-icon">🤖</div><div class="stat-info"><div class="stat-value"><%= overview.todayApiCalls %></div><div class="stat-label">今日 AI 调用</div></div></div>
        </div>

        <div class="chart-grid">
            <div class="card chart-card"><div class="card-header"><h3>📈 用户活跃趋势</h3>
                    <div class="chart-actions">
                        <button class="btn btn-sm active" onclick="loadTrend(7, this)">7 天</button>
                        <button class="btn btn-sm" onclick="loadTrend(30, this)">30 天</button>
                    </div>
                </div>
                <div class="card-body"><canvas id="trendChart" height="200"></canvas></div>
            </div>
            <div class="card chart-card">
                <div class="card-header"><h3>🖥️ 平台分布</h3></div>
                <div class="card-body"><canvas id="platformChart" height="200"></canvas></div>
            </div>
        </div>

        <!-- 用户增长趋势 -->
        <div class="chart-grid">
            <div class="card chart-card chart-card-wide">
                <div class="card-header"><h3>👥 用户增长趋势</h3>
                    <div class="chart-actions">
                        <button class="btn btn-sm" onclick="loadUserGrowth(7, this)">7 天</button>
                        <button class="btn btn-sm active" onclick="loadUserGrowth(30, this)">30 天</button>
                        <button class="btn btn-sm" onclick="loadUserGrowth(90, this)">90 天</button>
                    </div>
                </div>
                <div class="card-body"><canvas id="userGrowthChart" height="180"></canvas></div>
            </div>
        </div>

        <!-- API 调用量趋势 -->
        <div class="chart-grid">
            <div class="card chart-card chart-card-wide">
                <div class="card-header"><h3>🤖 接口调用量统计</h3>
                    <div class="chart-actions">
                        <button class="btn btn-sm active" onclick="loadApiCallTrend(7, this)">7 天</button>
                        <button class="btn btn-sm" onclick="loadApiCallTrend(30, this)">30 天</button>
                        <button class="btn btn-sm" onclick="loadApiCallTrend(90, this)">90 天</button>
                    </div>
                </div>
                <div class="card-body"><canvas id="apiCallChart" height="220"></canvas></div>
            </div>
        </div>

        <div class="chart-grid">
            <div class="card chart-card chart-card-wide">
                <div class="card-header"><h3>🧩 插件使用统计</h3></div>
                <div class="card-body"><canvas id="pluginChart" height="160"></canvas></div>
            </div>
        </div>

        <div class="card">
            <div class="card-header"><h3>🕐 最近上线用户</h3></div>
            <div class="card-body">
                <table class="table">
                    <thead><tr><th>用户</th><th>平台</th><th>最后心跳</th><th>IP</th></tr></thead>
                    <tbody>
                        <% recentUsers.forEach(function(u) { %>
                        <tr>
                            <td><div class="user-cell"><span class="status-dot online"></span><span><%= u.user_name || u.user_id || u.id %></span></div></td>
                            <td><span class="badge"><%= u.platform || '-' %></span></td>
                            <td><%= formatTime(u.last_heartbeat) || '-' %></td>
                            <td><%= u.ip_address || '-' %></td>
                        </tr>
                        <% }); %>
                        <% if (recentUsers.length === 0) { %>
                        <tr><td colspan="4" class="text-center text-muted">暂无用户数据</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>
<script src="/admin/js/dashboard.js"></script>
</body>
</html>
