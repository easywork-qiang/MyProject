<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>用户详情 - RC Assist 管理后台</title>
    <link rel="stylesheet" href="/admin/css/style.css">
</head>
<body>
<div class="app-container">
    <%- include('layout') %>
    <main class="main-content">
        <div class="page-header">
            <h1>👤 用户详情</h1>
            <a href="/admin/users" class="btn btn-sm">← 返回列表</a>
        </div>

        <div class="detail-grid">
            <div class="card">
                <div class="card-header"><h3>基本信息</h3></div>
                <div class="card-body">
                    <div class="detail-row"><span class="detail-label">用户 ID</span><span class="detail-value"><code><%= client.user_id || '-' %></code></span></div>
                    <div class="detail-row"><span class="detail-label">用户名</span><span class="detail-value"><%= client.user_name || '-' %></span></div>
                    <div class="detail-row"><span class="detail-label">部门</span><span class="detail-value"><%= client.dept_name || '-' %></span></div>
                    <div class="detail-row"><span class="detail-label">公司</span><span class="detail-value"><%= client.company_name || '-' %></span></div>
                    <div class="detail-row"><span class="detail-label">平台</span><span class="detail-value"><span class="badge"><%= client.platform || '-' %></span></span></div>
                    <div class="detail-row"><span class="detail-label">IP 地址</span><span class="detail-value"><%= client.ip_address || '-' %></span></div>
                    <div class="detail-row"><span class="detail-label">首次上线</span><span class="detail-value"><%= formatTime(client.first_seen) || '-' %></span></div>
                    <div class="detail-row"><span class="detail-label">最后心跳</span><span class="detail-value"><%= formatTime(client.last_heartbeat) || '-' %></span></div>
                </div>
            </div>

            <div class="card">
                <div class="card-header"><h3>⚙️ Core 组件</h3></div>
                <div class="card-body">
                    <% 
                    var coreComps = [];
                    try { coreComps = JSON.parse(client.core_components || '[]'); } catch(e) {}
                    %>
                    <% if (coreComps.length > 0) { %>
                    <table class="table">
                        <thead><tr><th>组件 ID</th><th>版本</th></tr></thead>
                        <tbody>
                            <% coreComps.forEach(function(c) { %>
                            <tr>
                                <td><%= c.id %></td>
                                <td><%= c.version || '-' %></td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                    <% } else { %>
                    <p class="text-muted text-center">暂无 Core 组件信息</p>
                    <% } %>
                </div>
            </div>

            <div class="card">
                <div class="card-header"><h3>🧩 插件配置</h3></div>
                <div class="card-body">
                    <% 
                    var plugins = [];
                    try { plugins = JSON.parse(client.plugin_config || '[]'); } catch(e) {}
                    %>
                    <% if (plugins.length > 0) { %>
                    <table class="table">
                        <thead><tr><th>插件 ID</th><th>版本</th><th>状态</th></tr></thead>
                        <tbody>
                            <% plugins.forEach(function(p) { %>
                            <tr>
                                <td><%= p.id %></td>
                                <td><%= p.version || '-' %></td>
                                <td><span class="badge <%= p.enabled ? 'badge-success' : 'badge-muted' %>"><%= p.enabled ? '启用' : '禁用' %></span></td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                    <% } else { %>
                    <p class="text-muted text-center">暂无插件配置信息</p>
                    <% } %>
                </div>
            </div>

            <div class="card" style="grid-column: 1 / -1;">
                <div class="card-header"><h3>🤖 AI 接口调用统计（近30天）</h3></div>
                <div class="card-body">

                    <% if (aiUsageDaily && aiUsageDaily.length > 0) { %>
                    <table class="table">
                        <thead>
                            <tr>
                                <th>日期</th>
                                <th>接口</th>
                                <th>调用次数</th>
                                <th>成功</th>
                                <th>失败</th>
                                <th>平均耗时</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% aiUsageDaily.forEach(function(row) { %>
                            <tr>
                                <td><%= row.call_date ? new Date(row.call_date).toISOString().split('T')[0] : '-' %></td>
                                <td><span class="badge"><%= row.endpoint %></span></td>
                                <td><%= row.call_count %></td>
                                <td style="color: #27ae60;"><%= row.success_count %></td>
                                <td style="color: #e74c3c;"><%= row.error_count %></td>
                                <td><%= row.avg_duration ? row.avg_duration + ' ms' : '-' %></td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                    <% } else { %>
                    <p class="text-muted text-center">暂无 AI 接口调用记录</p>
                    <% } %>
                </div>
            </div>

            <div class="card" style="grid-column: 1 / -1;">
                <div class="card-header"><h3>📋 最近调用明细（最新20条）</h3></div>
                <div class="card-body">
                    <% if (aiUsageRecent && aiUsageRecent.length > 0) { %>
                    <table class="table">
                        <thead>
                            <tr>
                                <th>时间</th>
                                <th>接口</th>
                                <th>状态</th>
                                <th>耗时</th>
                                <th>Tokens</th>
                                <th>错误信息</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% aiUsageRecent.forEach(function(row) { %>
                            <tr>
                                <td><%= formatTime(row.created_at) %></td>
                                <td><span class="badge"><%= row.endpoint %></span></td>
                                <td>
                                    <span class="badge <%= row.status === 'success' ? 'badge-success' : 'badge-danger' %>">
                                        <%= row.status === 'success' ? '✅ 成功' : '❌ 失败' %>
                                    </span>
                                </td>
                                <td><%= row.duration_ms ? row.duration_ms + ' ms' : '-' %></td>
                                <td><%= row.tokens_used || '-' %></td>
                                <td style="color: #e74c3c; font-size: 12px;"><%= row.error_message || '' %></td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                    <% } else { %>
                    <p class="text-muted text-center">暂无调用明细</p>
                    <% } %>
                </div>
            </div>
        </div>

    </main>
</div>
</body>
</html>
