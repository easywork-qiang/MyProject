<!-- 移动端遮罩层 -->
<div class="sidebar-overlay" onclick="document.body.classList.remove('sidebar-open')"></div>

<!-- 移动端顶部导航 -->
<div class="mobile-header">
  <div class="logo">
    <span class="logo-icon">🚀</span>
    <span class="logo-text" style="color: var(--text-primary);">RC Assist</span>
  </div>
  <button class="mobile-menu-toggle" onclick="document.body.classList.toggle('sidebar-open')">
    <span style="font-size: 24px;">☰</span>
  </button>
</div>

<!-- 侧边导航 partial -->
<aside class="sidebar">
  <div class="sidebar-header">
    <div class="logo">
      <span class="logo-icon">🚀</span>
      <span class="logo-text">RC Assist</span>
      <button class="mobile-menu-close" onclick="document.body.classList.remove('sidebar-open')">✕</button>
    </div>
  </div>
  <nav class="sidebar-nav">
    <a
      href="/admin/dashboard"
      class="nav-item <%= page === 'dashboard' ? 'active' : '' %>"
    >
      <span class="nav-icon">📊</span><span class="nav-text">概览</span>
    </a>
    <a
      href="/admin/users"
      class="nav-item <%= page === 'users' ? 'active' : '' %>"
    >
      <span class="nav-icon">👥</span><span class="nav-text">用户管理</span>
    </a>
    <a
      href="/admin/plugins"
      class="nav-item <%= page === 'plugins' ? 'active' : '' %>"
    >
      <span class="nav-icon">🧩</span><span class="nav-text">插件管理</span>
    </a>
    <a
      href="/admin/api-stats"
      class="nav-item <%= page === 'api-stats' ? 'active' : '' %>"
    >
      <span class="nav-icon">🤖</span><span class="nav-text">AI 统计</span>
    </a>
    <a
      href="/admin/audit-logs"
      class="nav-item <%= page === 'audit-logs' ? 'active' : '' %>"
    >
      <span class="nav-icon">📋</span><span class="nav-text">审计日志</span>
    </a>
  </nav>
  <div class="sidebar-footer">
    <div class="user-info">
      <span class="user-avatar">👤</span>
      <span class="user-name"><%= admin.username %></span>
    </div>
    <a href="/admin/logout" class="logout-btn">退出</a>
  </div>
</aside>
